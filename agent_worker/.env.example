# Hermes LiveKit bridge environment template

# LiveKit Cloud / dispatch. These must match the web frontend.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=...
LIVEKIT_API_SECRET=...
LIVEKIT_AGENT=my-hermes-agent

# Hermes API. For Level 3, run this worker on the Hermes host and keep this local.
HERMES_API_URL=http://127.0.0.1:8642
HERMES_API_KEY=... # same value as API_SERVER_KEY

# Current Telegram session/thread. Update if the Telegram session is reset/compressed.
HERMES_SESSION_ID=20260601_175300_d7d884
HERMES_SESSION_KEY=telegram:6340716310

# Optional LiveKit inference model choices.
HERMES_STT_MODEL=deepgram/nova-3
HERMES_TTS_MODEL=cartesia/sonic-3
HERMES_TTS_VOICE=9626c31c-bec5-4cca-baa8-f8ba9e84c8bc
HERMES_API_TIMEOUT_SECONDS=300
